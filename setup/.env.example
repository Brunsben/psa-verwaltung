# ─────────────────────────────────────────────────────────────
#  PSA-Verwaltung – Umgebungsvariablen
#  Kopiere diese Datei als ".env" und trage deine Werte ein.
#  Die Datei ".env" wird NICHT in Git gespeichert.
# ─────────────────────────────────────────────────────────────

# PostgreSQL-Datenbank
POSTGRES_USER=nocodb
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=nocodb

# NocoDB JWT-Secret (langer, zufälliger String)
NC_AUTH_JWT_SECRET=change-me-random-secret-at-least-32-chars

# NocoDB API-Token
# Erstelle ihn nach dem ersten Login:
#   NocoDB UI → rechts oben Nutzerbild → "Team & Settings" → "API Tokens" → Token erstellen
XC_TOKEN=your-nocodb-api-token-here

# NocoDB URL (nur für nocodb-setup.sh; Standard: http://localhost:8181)
# NOCODB_URL=http://localhost:8181
