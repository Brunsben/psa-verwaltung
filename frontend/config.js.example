    Ausruestungstypen:  'YOUR_TABLE_ID',
    Ausruestungstuecke: 'YOUR_TABLE_ID',
    Ausgaben:           'YOUR_TABLE_ID',
    Pruefungen:         'YOUR_TABLE_ID',
    Waesche:            'YOUR_TABLE_ID',
  }
};
