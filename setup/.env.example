# ─────────────────────────────────────────────────────────────
#  PSA-Verwaltung – Umgebungsvariablen
#  Kopiere diese Datei als ".env" und trage deine Werte ein.
#  Die Datei ".env" wird NICHT in Git gespeichert.
# ─────────────────────────────────────────────────────────────

# PostgreSQL-Datenbank
POSTGRES_USER=nocodb
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=nocodb

# PostgREST-Datenbankpasswort (für die psa_auth-Rolle)
POSTGREST_DB_PASSWORD=change-me-postgrest-password
